{
  "expo": {
    "name": "canilendar",
    "slug": "canilendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon.png",
    "scheme": "canilendar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Canilendar uses notifications to remind you about your dog walking appointments and daily schedule."
      },
      "bundleIdentifier": "com.anonymous.canilendar"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favicon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Canilendar uses the camera so you can add a dog photo directly to a dog profile.",
          "photosPermission": "Canilendar uses your photo library so you can attach an existing dog photo to a dog profile."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-screen.png",
          "imageWidth": 400,
          "resizeMode": "contain",
          "backgroundColor": "#F8F1E6",
          "dark": {
            "backgroundColor": "#F8F1E6"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
