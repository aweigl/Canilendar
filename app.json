{
  "expo": {
    "name": "canilendar",
    "slug": "canilendar",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/favicon_2.png",
    "scheme": "canilendar",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aweigl.canilendar",
      "entitlements": {
        "com.apple.developer.applesignin": ["Default"]
      },
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Canilendar uses notifications to remind you about your dog walking appointments and daily schedule.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/favicon_2.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon_2.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Canilendar uses the camera so you can add a dog photo directly to a dog profile.",
          "photosPermission": "Canilendar uses your photo library so you can attach an existing dog photo to a dog profile."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash_screen.png",
          "imageWidth": 1024,
          "resizeMode": "cover",
          "enableFullScreenImage_legacy": true,
          "backgroundColor": "#F8F1E6",
          "dark": {
            "image": "./assets/images/splash_screen.png",
            "imageWidth": 1024,
            "resizeMode": "cover",
            "backgroundColor": "#F8F1E6"
          }
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d129f7e-f089-44e6-bf5f-51a3eb55cf76"
      }
    }
  }
}
