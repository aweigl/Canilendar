{
  "cli": {
    "version": ">= 16.18.0",
    "appVersionSource": "remote"
  },
  "build": {
    "base": {
      "env": {
        "EXPO_PUBLIC_ENABLE_APPLE_AUTH": "true"
      }
    },
    "development": {
      "extends": "base",
      "environment": "development",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "ios-simulator": {
      "extends": "development",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_ENABLE_APPLE_AUTH": "false"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "extends": "production",
      "environment": "preview",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "base",
      "environment": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }
}
